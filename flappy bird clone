# Flappy Bird Clone

import pygame
import random

# Initialize pygame
pygame.init()

# Screen
width = 500
height = 700

screen = pygame.display.set_mode((width, height))
pygame.display.set_caption("Flappy Bird")

# Colors
white = (255, 255, 255)
blue = (135, 206, 235)
green = (0, 255, 0)
yellow = (255, 255, 0)

# Clock
clock = pygame.time.Clock()

# Bird
bird_x = 100
bird_y = 300
bird_radius = 20

gravity = 0.5
bird_movement = 0

# Pipes
pipe_width = 70
pipe_gap = 180
pipe_speed = 4

pipes = []

# Font
font = pygame.font.SysFont(None, 40)

score = 0

# Create pipes
def create_pipe():

    pipe_height = random.randint(150, 450)

    top_pipe = pygame.Rect(width, 0, pipe_width, pipe_height)

    bottom_pipe = pygame.Rect(
        width,
        pipe_height + pipe_gap,
        pipe_width,
        height
    )

    return top_pipe, bottom_pipe

# Draw pipes
def draw_pipes(pipes):

    for top, bottom in pipes:

        pygame.draw.rect(screen, green, top)

        pygame.draw.rect(screen, green, bottom)

# Collision check
def check_collision(pipes):

    bird_rect = pygame.Rect(
        bird_x - bird_radius,
        bird_y - bird_radius,
        bird_radius * 2,
        bird_radius * 2
    )

    for top, bottom in pipes:

        if bird_rect.colliderect(top) or bird_rect.colliderect(bottom):
            return True

    if bird_y <= 0 or bird_y >= height:
        return True

    return False

# Main game loop
running = True

pipe_timer = 0

while running:

    screen.fill(blue)

    # Events
    for event in pygame.event.get():

        if event.type == pygame.QUIT:
            running = False

        if event.type == pygame.KEYDOWN:

            if event.key == pygame.K_SPACE:
                bird_movement = -8

    # Bird movement
    bird_movement += gravity

    bird_y += bird_movement

    pygame.draw.circle(screen, yellow, (bird_x, int(bird_y)), bird_radius)

    # Pipes
    pipe_timer += 1

    if pipe_timer > 90:

        pipes.append(create_pipe())

        pipe_timer = 0

    new_pipes = []

    for top, bottom in pipes:

        top.x -= pipe_speed
        bottom.x -= pipe_speed

        if top.x + pipe_width > 0:
            new_pipes.append((top, bottom))







