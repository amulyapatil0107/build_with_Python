# Emoji Translator

emoji_dictionary = {
    "happy": "😊",
    "sad": "😢",
    "love": "❤️",
    "fire": "🔥",
    "cool": "😎",
    "angry": "😡",
    "laugh": "😂",
    "sleep": "😴"
}

sentence = input("Enter a sentence: ").lower()

words = sentence.split()

translated = ""

for word in words:

    if word in emoji_dictionary:
        translated += emoji_dictionary[word] + " "




